{
  "manifest_version": 3,
  "name": "JobFill Pro - Auto Application Assistant",
  "short_name": "JobFill Pro",
  "version": "1.1.0",
  "description": "Batch-apply to multiple LinkedIn jobs in the background. Auto-fills Workday, Greenhouse, Lever, Taleo & more. Resume auto-upload included.",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "activeTab",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.myworkdayjobs.com/*",
    "https://*.workday.com/*",
    "https://boards.greenhouse.io/*",
    "https://*.greenhouse.io/*",
    "https://jobs.lever.co/*",
    "https://*.lever.co/*",
    "https://*.taleo.net/*",
    "https://*.icims.com/*",
    "https://www.indeed.com/*",
    "https://apply.indeed.com/*",
    "https://*.indeed.com/*",
    "https://*.jobvite.com/*",
    "https://*.smartrecruiters.com/*",
    "https://*.oraclecloud.com/*",
    "https://apply.oracle.com/*",
    "https://*.oracle.com/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://www.linkedin.com/feed/",
        "https://*.myworkdayjobs.com/*",
        "https://*.workday.com/*/job/*",
        "https://boards.greenhouse.io/*",
        "https://*.greenhouse.io/jobs/*",
        "https://jobs.lever.co/*",
        "https://*.lever.co/*",
        "https://*.taleo.net/*",
        "https://*.icims.com/*",
        "https://www.indeed.com/viewjob*",
        "https://apply.indeed.com/*",
        "https://*.jobvite.com/careers*",
        "https://*.smartrecruiters.com/*",
        "https://*.oraclecloud.com/*",
        "https://apply.oracle.com/*",
        "https://*.oracle.com/*/careers/*",
        "https://*.oracle.com/*/jobs/*"
      ],
      "js": ["utils.js", "contentScript.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "JobFill Pro",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
